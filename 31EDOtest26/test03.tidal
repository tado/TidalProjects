let edo = 31 -- 31EDOの1オクターブのステップ数
    e31 p = p |* note (12/edo)
    -- 31EDOのルート音(ステップ数): 全音 = 5、全音階的半音 = 3
    roots31 = [("c",0),("d",5),("e",10),("f",13),("g",18),("a",23),("b",28)]
    -- 変化記号: s/f = 半音階的半音(2ステップ)、hs/hf = 半シャープ/半フラット(1ステップ)
    accs31 = [("",0),("s",2),("f",-2),("hs",1),("hf",-1)]
    -- 和音の種類(31EDOステップで定義)
    quals31 =
      [ ("maj",     [0,10,18])     -- 長三和音、3度 ≈ 5:4
      , ("min",     [0,8,18])      -- 短三和音、3度 ≈ 6:5
      , ("neut",    [0,9,18])      -- 中立3度 ≈ 11:9
      , ("submin",  [0,7,18])      -- サブマイナー、3度 ≈ 7:6
      , ("supmaj",  [0,11,18])     -- スーパーメジャー、3度 ≈ 9:7
      , ("dim",     [0,8,16])
      , ("aug",     [0,10,20])
      , ("sus2",    [0,5,18])
      , ("sus4",    [0,13,18])
      , ("maj7",    [0,10,18,28])
      , ("min7",    [0,8,18,26])
      , ("dom7",    [0,10,18,26])
      , ("harm7",   [0,10,18,25])  -- 自然7度和音 4:5:6:7
      , ("submin7", [0,7,18,25])
      ]
    chordTable31 =
      [ (r ++ a ++ sep ++ q, stack (map (pure . (+ (rv + av))) steps))
      | (r,rv) <- roots31, (a,av) <- accs31, sep <- [":", "'"], (q,steps) <- quals31 ]
    ch31 p = e31 (note (inhabit chordTable31 p))
    -- 和音イベントを n 等分の一定グリッドにし、構成音を下から順に循環させる
    -- (arp は構成音の数だけ音を置くため、3和音と4和音でリズムが変わってしまう)
    arpSteady :: Int -> Pattern a -> Pattern a
    arpSteady n = arpWith (\es -> map (\i -> es !! (i `mod` length es)) [0 .. n-1])
    -- 31EDO特有のスケール(31ステップのオクターブ内のステップ数で定義)
    scales31 :: [(String, [Note])]
    scales31 =
      [ ("orwell9",   [0,4,7,11,14,18,21,25,28])  -- Orwell[9]、生成音程 7\31(サブマイナー3度)
      , ("mohajira",  [0,5,9,14,18,23,27])        -- 中立3度(≈11:9)による7音スケール
      , ("harmonics", [0,5,10,14,18,22,25,28])    -- 倍音列 第8〜16倍音(第11・13倍音を含む)
      , ("major",     [0,5,10,13,18,23,28])       -- ミーントーン全音階の長調
      , ("minor",     [0,5,8,13,18,21,26])        -- ミーントーン自然的短音階
      ]
    -- Tidalのscale関数と同じ使い方、ただしオクターブは31ステップで折り返す
    step31 sc x = sc !! (x `mod` length sc) + fromIntegral (31 * (x `div` length sc))
    scale31 :: Pattern String -> Pattern Int -> Pattern Note
    scale31 sp p = innerJoin (fmap (\name -> fmap (step31 (maybe [0] id (lookup name scales31))) p) sp)
    -- 64サイクルの形式(60BPM: 1サイクル4秒、全体で約4分16秒)
    -- ドローンの基音は C に留まり、第3セクションのみ完全4度下の G へ沈んで戻る
    -- C -> C -> G -> C、各16サイクル。動きは基音の上の和音と音色に委ねる
    key31 :: Pattern Note
    key31 = slow 16 "<0 0 -13 0>"
    inKey p = p |+ e31 (note key31)
    -- 形式の最終サイクル: 全体が1ディエシス(38.7セント)下にスライドする
    pump = whenmod 64 63 (|- e31 (note 1))

hush

setcps(65/240)

do
  resetCycles
  -- d1: サブドローン — 基音と完全5度(18)だけの土台
  d1
    $ pump . inKey
    $ slow 8
    $ s "superhammond"
    # voice 9
    # e31 (note "[0, 18]")
    |+ note "[c2, c3, c4]"
    |* note "[0.9999, 1.0001]"
    -- # legato 1.0
    -- # lpf 2000 # resonance 0.3
    -- # leslie 0.8 # lrate 1.2
    # room 0.3 # size 0.9
    # gain 1.0
  -- d2: 和音パッド — すべての和音が基音 C を共通音として含む
  -- c:harm7(4:5:6:7) から出発し、C を保持したまま根音だけが回り、c:maj7 で7度が
  -- 28 に持ち上がったあと harm7 の 25 へ落ちて(3ステップ ≈ 116セント)ループする
  d2
    $ pump . inKey
    $ slow 2
    $ s "supersinfade"
    # ch31 "<c:harm7 f:supmaj d:min7 g:sus4 ahf:neut f:submin7 ahs:submin c:maj7>"
    |+ note "[c5, c6]"
    |* note "[1.0001, 0.9999]"
    # legato 2
    -- # leslie 0.2 # lrate 1.0
    # room 0.9 # size 0.9
    # gain 1.2

-- d3: 倍音のきらめき — セクションごとにスケールの色が変わる高音の遅いアルペジオ
-- harmonics(倍音列)×2 -> mohajira(中立3度) -> orwell9 と、基音は動かさず色だけ変える
d3
  $ pump . inKey
  $ jux ((1/3) <~)
  $ s "supersin"
  # e31 (note (scale31 (slow 16 "<harmonics harmonics mohajira orwell9>") "<0 4 7 2 9 5 11 7>*2"))
  |+ note "c6"
  # delay 0.9 # delaytime (3/4) # delayfb 0.6 # lock 1
  # lpf (range 1000 6000 $ slow 32 $ sine) # resonance 0.15
  # legato 2
  # gain 0.8

-- d4: まれに鳴る鐘 — 自然7度(25)・第13倍音(22)・5度(18)・中立7度(27)のあいだを漂う単音
d4
  $ pump . inKey
  $ degradeBy 0.4
  $ struct "t(<2 3 2 5>, 14)"
  $ s "superfork"
  # e31 (note "<25 22 18 27>")
  |+ note "c5"
  # delay 0.8 # delaytime (9/14) # delayfb 0.5 # lock 1
  # room 0.9 # size 0.9
  # legato 3
  # gain 0.85

-- d5: ハモンドのアルペジオ — d2と同じ和音進行(chordTable31)を分散和音で辿る
-- 各和音(1/2サイクル=2秒)の構成音を arpSteady で16分音符の一定グリッドに並べる
d5
  $ pump . inKey
  $ sometimesBy 0.75 (fast 2)
  $ jux (rev)
  $ e31 (note (arpSteady 14 (inhabit chordTable31 "<c:harm7 f:supmaj d:min7 g:sus4 ahf:neut f:submin7 ahs:submin c:maj7>")))
  # s "superhammond"
  # voice 4
  |+ note "[c5, c6]"
  |* note "[1.001, 0.999]"
  # delay 0.9 # delaytime ("[9, 5]"/14) # delayfb 0.5 # lock 1
  -- # leslie 0.4 # lrate 0.7
  # room 0.3 # size 0.95
  -- # legato 1
  # gain 0.7

d6
  $ jux (("[3, 9]"/14)<~)
  $ stack
  [
    s "uni(3, 14)" # gain 1.5
    , s "uni:1(9, 14, 2)"
  ]
  -- # delay 0.8 # delaytime (9/14) # delayfb "0.5" # lock 1  
  |* gain 1.7

d7
  -- $ jux (("[13, 5]"/14)<~)
  -- 14グリッド上に3層のリズムを重ね、ply でロールを差し込む
  $ sometimesBy 0.15 (ply "<2 3>")
  $ stack
  [ -- 主軸: パルス数がサイクルごとに変わるユークリッド
    s "ifdrums(<7 10 9 11>, 14)"
    # n (range 1 4 $ rand)
    # gain 1.0
  , -- 裏打ち: オフセットがずれていくカウンターリズム
    s "ifdrums(<3 5>, 14, <0 3 6>)"
    # n (range 4 8 $ rand)
    # speed 2 # gain 0.85
  , -- 細分化: 28分割(14×2)を虫食いにしたチャター
    degradeBy 0.55
    $ s "ifdrums*28"
    # n (irand 8)
    # speed 4 # gain 0.75
  ]
  # shape 0.7
  |* gain 1.1

-- d8: ベース — d2の和音進行の根音を、d6/d7と同じ14グリッドのユークリッドで刻む
-- 根音は c2 に近いオクターブへ畳む(g→-13、ahf→-9、ahs→-7)ので跳躍が小さい
-- 和音は2サイクルごと(d2と同期)、パルス数は d7 と同様にサイクルごとに変わる
d8
  $ pump . inKey
  $ struct "t(<13 7 11 9>*8, 14)"
  $ s "superbass"
  # e31 (note (slow 2 "<0 13 5 -13 -9 13 -7 0>"))
  |+ note "[c2, c3]"
  |+ note "[-0.02, 0.02]"
  -- # lpf (range 500 2500 $ slow 8 $ sine) # resonance 0.2
  -- # legato 0.9
  # shape 0.3
  # gain 1.5

