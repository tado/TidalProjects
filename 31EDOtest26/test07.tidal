setcps (135/240)
  
let shift31 = "<0 8 10 18 23>/5"
    chordRegister31 = "<-31 -62>*8"   -- C4, C3 relative to C5
    spreadRegister31 = "[-31, -62, 31]"
    sampleNumber = 2
    phraseLegato = 1.5

hush

d1
  -- $ jux (("[9, 5]"/7)<~)
  $ up31 shift31
  $ s "gambon(5, 7)"
  |+ note "c4"
  # n sampleNumber
  # sc31 (slow 2 "<harmminor>") "{0..12}%[11, 19]"
  # room 0.9
  # legato phraseLegato

d2
  -- $ jux (("[7, 3]"/14)<~)
  $ arpSteady 14
  $ ch31 "<c:harm11>"
  # s "gambon"
  |+ note "c5"
  # n sampleNumber
  # legato phraseLegato
  # room 0.9

d3
  $ jux ((3/7)~>)
  $ up31 shift31
  $ s "gambon(2, 7)"
  # n sampleNumber
  # ch31 "<c:harm11>"
  |+ note "[c4, c5]"
  # room 0.9
  # legato phraseLegato

d4
  $ sometimesBy 0.2 (fast 2)
  $ stack
  [ s "uni(3, 7)"
    , s "uni:1(3, 7, 1)"
    , s "ifdrums(5, 7, 2)" # n (irand 3) # gain 0.9
  ]
  |* gain 1.2

d5
  $ up31 shift31
  $ s "gambon"
  # n31 "<c2 c3>"
  # legato 4
  # room 0.9

hush
