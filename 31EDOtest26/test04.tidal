-- ============================================================
-- 31EDO ライブラリ: 音程 (e31)・和音 (ch31)・スケール (scale31)
-- ============================================================
-- この let ブロックを1回評価すれば、以下がすべて使えるようになる。
--   e31     : 31EDOステップ数のパターン → note(音程の中核)
--   n31     : 音名のパターン → 単音("c" "ds" "ahf" "g6" など)
--   ch31    : 和音名のパターン → 和音("c:harm7" など)
--   arpSteady : 和音を一定グリッドのアルペジオに展開(ch31 と組み合わせる)
--   scale31 : スケール名と度数のパターン → ステップ数(e31 と組み合わせる)
--   scale31on : ルート音名付きの scale31(スケールを任意のルート上に移調)

let -- ── 音程の中核 ──────────────────────────────────────────
    -- Tidal の note は「半音」単位(12EDO)の数値で、SuperDirt が
    -- freq = 基準周波数 × 2^(note/12) に変換する。31EDO の1ステップは
    -- 1オクターブ(=12半音)の 1/31 なので、ステップ数に 12/31 を
    -- 掛けるだけでよい。
    --   1 ステップ  = 12/31 半音 ≈ 38.71 セント(ディエシス)
    --   31 ステップ = ちょうど 1 オクターブ
    -- 音程の生成はこの2行がすべてで、以下の定義(音名・和音・スケール)は
    -- ステップ数を計算するための語彙にすぎない。
    edo = 31
    e31 p = p |* note (12/edo)
    -- ── 和音 ────────────────────────────────────────────────
    -- 1. roots31 / accs31 … 音名 → ステップ数の辞書
    --    ルート:   c=0 d=5 e=10 f=13 g=18 a=23 b=28(全音=5、半音=3)
    --    変化記号: s/f = シャープ/フラット(±2)、hs/hf = 半シャープ/半フラット(±1)
    roots31 = [("c",0),("d",5),("e",10),("f",13),("g",18),("a",23),("b",28)]
    accs31 = [("",0),("s",2),("f",-2),("hs",1),("hf",-1)]
    -- 2. quals31 … 和音の種類(根音からの31EDOステップ数のリスト)
    quals31 =
      [ ("maj",     [0,10,18])     -- 長三和音、3度 ≈ 5:4
      , ("min",     [0,8,18])      -- 短三和音、3度 ≈ 6:5
      , ("neut",    [0,9,18])      -- 中立3度 ≈ 11:9(31EDO特有)
      , ("submin",  [0,7,18])      -- サブマイナー、3度 ≈ 7:6(31EDO特有)
      , ("supmaj",  [0,11,18])     -- スーパーメジャー、3度 ≈ 9:7(31EDO特有)
      , ("dim",     [0,8,16])      -- 減三和音
      , ("aug",     [0,10,20])     -- 増三和音
      , ("sus2",    [0,5,18])
      , ("sus4",    [0,13,18])
      , ("maj7",    [0,10,18,28])
      , ("min7",    [0,8,18,26])
      , ("dom7",    [0,10,18,26])
      , ("harm7",   [0,10,18,25])  -- 自然7度和音 4:5:6:7(31EDO特有)
      , ("submin7", [0,7,18,25])   -- サブマイナー7
      ]
    -- 3. chordTable31 … ルート×変化記号×種類 の全組み合わせから
    --    「名前 → 和音(ステップ数の stack)」の対応表を作る。
    --    ch31 は inhabit でパターン中の名前を表から引き、e31 で音程に変換する。
    chordTable31 =
      [ (r ++ a ++ sep ++ q, stack (map (pure . (+ (rv + av))) steps))
      | (r,rv) <- roots31, (a,av) <- accs31, sep <- [":", "'"], (q,steps) <- quals31 ]
    ch31 p = e31 (note (inhabit chordTable31 p))
    -- ── アルペジオ(和音を分散して鳴らす)────────────────────
    -- 和音イベントを n 等分の一定グリッドにし、構成音を下から順に循環させる。
    -- (標準の arp は構成音の数だけ音を置くため、3和音と4和音が混ざると
    --  リズムが不均等になる。arpSteady は和音の音数によらず一定になる)
    -- 例: arpSteady 8 (ch31 "<c:maj f:harm7>") — 各和音を8音の分散和音に
    arpSteady :: Int -> Pattern a -> Pattern a
    arpSteady n = arpWith (\es -> map (\i -> es !! (i `mod` length es)) [0 .. n-1])
    -- ── 単音(音名で呼び出す)────────────────────────────────
    -- roots31 × accs31 × オクターブ番号 の対応表。和音と同じ inhabit 方式。
    --   "c" "ds" "ehf" のような素の名前はオクターブ5(note 0 の高さ)、
    --   "c4" "ahf6" のように数字を付けるとオクターブ指定(c5 = 0 が基準)。
    -- 例: n31 "<c ds g>" |+ note "c2"(レジスタは note の加算でも動かせる)
    noteTable31 =
      [ (r ++ a ++ oname, pure (rv + av + fromIntegral (31 * (o - 5))))
      | (r,rv) <- roots31, (a,av) <- accs31
      , (oname,o) <- ("",5) : [(show n, n) | n <- [0..8 :: Int]] ]
    n31 p = e31 (note (inhabit noteTable31 p))
    -- ── スケール(音律)──────────────────────────────────────
    -- スケールは「オクターブ(31ステップ)内のステップ数のリスト」で定義。
    --   orwell9   : Orwell[9]。生成音程 7\31(サブマイナー3度 ≈7:6)による
    --               9音MOS。12EDOに存在しない、31EDOの代表的スケール
    --   mohajira  : 中立3度(9\31 ≈11:9)を積んだ7音スケール。アラブ音楽の
    --               ラースト系に近い、長短の中間の響き
    --   miracle10 : Miracle[10](デシマル)。セコール(3\31 ≈116.1セント)を
    --               生成音程とする10音のほぼ等間隔スケール
    --   harmonics : 倍音列の第8〜16倍音。第11・13倍音(14, 22)を含む
    --   major     : ミーントーン全音階の長調(31EDOは1/4コンマ・ミーントーン
    --               とほぼ同じなので、純正に近い長3度をもつ)
    --   minor     : ミーントーン自然的短音階
    --   chrom12   : ミーントーンの12音クロマチック(全音=5を 2+3 に分割)
    scales31 :: [(String, [Note])]
    scales31 =
      [ ("orwell9",   [0,4,7,11,14,18,21,25,28])
      , ("mohajira",  [0,5,9,14,18,23,27])
      , ("miracle10", [0,3,6,9,12,15,18,21,24,27])
      , ("harmonics", [0,5,10,14,18,22,25,28])
      , ("major",     [0,5,10,13,18,23,28])
      , ("minor",     [0,5,8,13,18,21,26])
      , ("chrom12",   [0,2,5,7,10,13,15,18,20,23,25,28])
      ]
    -- scale31 は Tidal 標準の scale と同じ使い方。度数がスケールの音数を
    -- 超えると 31ステップ(=1オクターブ)上に折り返す(負の度数は下へ)。
    step31 sc x = sc !! (x `mod` length sc) + fromIntegral (31 * (x `div` length sc))
    scale31 :: Pattern String -> Pattern Int -> Pattern Note
    scale31 sp p = innerJoin (fmap (\name -> fmap (step31 (maybe [0] id (lookup name scales31))) p) sp)
    -- scale31on はルート音名を指定して、スケールをそのルート上に移調する。
    -- 例: scale31on "d" "orwell9" "0 1 2" — D をルートにした orwell9 の 0〜2度
    -- (度数 0 = ルート音。和音のルートに合わせたチャーチモード的な使い方)
    scale31on :: Pattern String -> Pattern String -> Pattern Int -> Pattern Note
    scale31on rp sp p = scale31 sp p |+ inhabit noteTable31 rp

-- ============================================================
-- 使用例1: 音程 — 基音から順に31音(+オクターブ)を演奏
-- ============================================================
-- ステップ数を note パターンとして書き、e31 に通す。
-- "0 .. 31"(32音)を slow 4 で4サイクルに引き延ばす = 1サイクル8音。
--
-- 注意1: "{0 .. 31}%4" のような書き方は不可。{} の中では ".." が展開されず
--        全体が1ステップ扱いになり、期待どおりに列が進まない。
-- 注意2: superpiano(MdaPiano)は内部で音程を半音(12EDO)に丸めるため
--        マイクロトナルには使えない。freq をそのまま鳴らすシンセを使うこと。

d1
  $ s "superrhodes*8"
  # legato 0.9
  # note "c4"
  |+ e31 (note (slow 4 "0 .. 31"))

hush

-- ============================================================
-- 使用例2: 和音 — 名前で呼び出す
-- ============================================================
-- 名前の形式: ルート音名(+変化記号)+ ":" + 和音の種類
--   例: "c:maj"  "f:harm7"  "ds:min"(D#マイナー)  "ahf:neut"(A半フラットの中立和音)
--   区切りは ":" と "'" のどちらでも同じ("c'maj" でも可)
-- レジスタは普通の note の加算で決める
--
-- 下の進行は quals31 の全14種を1回ずつ使った、C を中心とする機能的な進行:
--   c:maj     I          … 主和音から出発
--   c:aug     I+         … 5度が半音上がる経過和音(20 → 次の 23 へ)
--   f:maj7    IVmaj7     … サブドミナント
--   d:min7    ii7        … 下属機能の連鎖
--   b:dim     vii°       … 導音上の減三和音(ドミナント機能)
--   c:sus2    Isus2      … いったん主和音圏へ柔らかく着地
--   a:min     vi         … 平行短調へ
--   d:submin  ii(7:6)    … ii の3度がセプティマルに沈む
--   g:sus4    Vsus4      … ドミナント準備
--   g:dom7    V7         … 4度が3度へ解決(31 → 28)する定番の流れ
--   c:harm7   I7(4:5:6:7)… 自然7度のトニック = IV へのセカンダリードミナント
--   f:supmaj  IV(9:7)    … 明るい9:7の3度で受ける(25 → 24)
--   d:neut    ii(11:9)   … 中立3度の ii で長短があいまいに
--   g:submin7 v7(7:6)    … 微分音の影を帯びたドミナントから c:maj へ戻る
do
  resetCycles
  -- ベース: 進行の根音を音名で(n31 で単音を呼び出す)
  d1
    -- $ slow 2
    $ s "superrhodes"
    # n31 "<c c f d b c a d g g c f d g>"
    |+ note "c3"
    # gain 0.9
  d2
    -- $ slow 2
    $ s "superrhodes"
    # ch31 "<c:maj c:aug f:maj7 d:min7 b:dim c:sus2 a:min d:submin g:sus4 g:dom7 c:harm7 f:supmaj d:neut g:submin7>"
    |+ note "c5"
    # gain 0.9

hush


-- ============================================================
-- 使用例3: スケール — 同じ度数の動きを音律を替えて演奏
-- ============================================================
-- scale31 <スケール名のパターン> <度数のパターン> → ステップ数(e31 で変換)。
-- 度数 0 が基音。2サイクルごとに major → mohajira → orwell9 → miracle10 と
-- スケールを持ち替える(音数が違うスケールでも度数の書き方は同じ)。

d3
  $ s "superrhodes*16"
  # e31 (note (scale31 (slow 2 "<major mohajira orwell9 miracle10>") "{0 .. 15}%11"))
  |+ note "c5"
  # legato 0.9
  # gain 0.9

hush

-- ============================================================
-- 使用例4: ベース(d1)+ 和音(d2)+ 音律(d3)の合奏 — 使用例2の全14種の進行
-- ============================================================
-- 使用例2と同じ、全14種の和音を1回ずつ使った進行(各1サイクル、
-- 14サイクルで一周)。旋律の音律は和音と1:1で同期させ、各和音に
-- 最も適したものを割り当てる:
--
--   c:maj→major(C)      c:aug→chrom12(C)   f:maj7→major(C)    d:min7→major(C)
--   b:dim→major(C)      c:sus2→major(C)    a:min→major(C)     d:submin→orwell9(D)
--   g:sus4→major(C)     g:dom7→major(C)    c:harm7→harmonics(C)
--   f:supmaj→orwell9(F)  d:neut→mohajira(C)  g:submin7→orwell9(G)
--
-- この進行は本質的にミーントーンの機能和声なので大半は C 上の major に
-- 収まり、色が変わる和音のところだけスケールが切り替わる:
--   c:aug の増5度(20)は major にないため、12音クロマチックで受ける
--   c:harm7 の自然7度(25)は harmonics で受ける
--   d:neut の中立3度(14)は mohajira だけが持っている
-- セプティマルな和音(d:submin / f:supmaj / g:submin7)の 7:6・9:7 の
-- 3度(12, 24)は C 基準のどのスケールにも含まれないが、orwell9 は
-- ルート上に submin(0,7,18)・supmaj(0,11,18)・submin7(0,7,18,25)を
-- すべて含む。そこでルート指定付きの scale31on を使い、orwell9 を
-- 和音のルート(D・F・G)上に移調して割り当てる。これで全14和音に
-- ついて「和音の構成音 ⊂ スケールの構成音」が成立する。

hush

do
  -- resetCycles
  -- ベース: 進行のルートを音名で演奏(n31 で単音、使用例2と同じ書き方)
  d1
    $ s "superbass"
    # n31 "<c c f d b c a d g g c f d g>"
    |+ note "c2"
    # legato 1
    # gain 0.9
  -- 和音: 全14種を使った機能的な進行(各和音1サイクル)
  d2
    $ s "superrhodes"
    # ch31 "<c:maj c:aug f:maj7 d:min7 b:dim c:sus2 a:min d:submin g:sus4 g:dom7 c:harm7 f:supmaj d:neut g:submin7>"
    |+ note "c4"
    # legato 1
    # gain 0.85
  -- アルペジオ: スケールを使わず、d2 と同じコードネームから直接生成する。
  -- arpSteady 8 が各和音(1サイクル)を8等分の一定グリッドにし、構成音を
  -- 下から順に循環させる(3和音なら 0,1,2,0,1,2,0,1 / 4和音なら 0..3 を2周)。
  -- 音はすべて和音の構成音そのものなので、和音との不整合は原理的に起きない。
  d3
    -- $ jux (("[3, 5]"/8)~>)
    -- $ sometimesBy 0.2 (fast 2)
    $ arpSteady 8
    $ ch31 "<c:maj c:aug f:maj7 d:min7 b:dim c:sus2 a:min d:submin g:sus4 g:dom7 c:harm7 f:supmaj d:neut g:submin7>"
    # s "superhammond"
    # voice 8
    |+ note "<c5 c6>*6"
    # legato 0.9
    # delay 0.7 # delaytime ("[5, 7]"/16) # delayfb 0.75 # lock 1
    # gain 0.7
  d4
    $ sometimesBy 0.1 (ply 2)
    $ s "uni(4, 8), hc(4, 8, 1)"
    # delay 0.25 # delaytime ("[4, 5]"/8) # delayfb 0.5 # lock 1
    # gain 0.75
    
     

-- 差し替え用: 旋律をスケール(scale31on)で弾く版。d3 をこちらで
-- 評価し直すと、和音ごとに最適な音律を割り当てた旋律に戻る。
 d3
  $ jux (("[3, 5]"/8)~>)
  $ sometimesBy 0.2 (fast 2)
  $ s "superhammond(7, 8)"
  # voice 8
  # e31 (note (scale31on "<c c c c c c c d c c c f c g>" "<major chrom12 major major major major major orwell9 major major harmonics orwell9 mohajira orwell9>" "{0..12}%5"))
  |+ note "<c5 c6>*8"
  # legato 1
  # gain 0.9

hush
