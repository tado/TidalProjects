-- ============================================================
-- 31EDO ライブラリ: 音程 (e31)・和音 (ch31)・スケール (scale31)
-- ============================================================
-- この let ブロックを1回評価すれば、以下がすべて使えるようになる。
--   e31     : 31EDOステップ数のパターン → note(音程の中核)
--   n31     : 音名のパターン → 単音("c" "ds" "ahf" "g6" など)
--   ch31    : 和音名のパターン → 和音("c:harm7" など)
--   arpSteady : 和音を一定グリッドのアルペジオに展開(ch31 と組み合わせる)
--   scale31 : スケール名と度数のパターン → ステップ数(e31 と組み合わせる)
--   scale31on : ルート音名付きの scale31(スケールを任意のルート上に移調)

let -- ── 音程の中核 ──────────────────────────────────────────
    -- Tidal の note は「半音」単位(12EDO)の数値で、SuperDirt が
    -- freq = 基準周波数 × 2^(note/12) に変換する。31EDO の1ステップは
    -- 1オクターブ(=12半音)の 1/31 なので、ステップ数に 12/31 を
    -- 掛けるだけでよい。
    --   1 ステップ  = 12/31 半音 ≈ 38.71 セント(ディエシス)
    --   31 ステップ = ちょうど 1 オクターブ
    -- 音程の生成はこの2行がすべてで、以下の定義(音名・和音・スケール)は
    -- ステップ数を計算するための語彙にすぎない。
    edo = 31
    e31 p = p |* note (12/edo)
    -- ── 和音 ────────────────────────────────────────────────
    -- 1. roots31 / accs31 … 音名 → ステップ数の辞書
    --    ルート:   c=0 d=5 e=10 f=13 g=18 a=23 b=28(全音=5、半音=3)
    --    変化記号: s/f = シャープ/フラット(±2)、hs/hf = 半シャープ/半フラット(±1)
    roots31 = [("c",0),("d",5),("e",10),("f",13),("g",18),("a",23),("b",28)]
    accs31 = [("",0),("s",2),("f",-2),("hs",1),("hf",-1)]
    -- 2. quals31 … 和音の種類(根音からの31EDOステップ数のリスト)
    --    協和 → 不協和 の順に並べてある。31EDOは協和の階調が12EDOより
    --    細かく、7-limit系(7/6, 7/5, 7/4)の和音が協和側に加わる一方、
    --    5度を1歩外しただけで鋭く濁るのが特徴。
    quals31 =
      -- ── 非常に協和(倍音列の整数比にほぼ一致)──
      [ ("maj",     [0,10,18])       -- 長三和音 ≈ 4:5:6(12EDOより純度が高い)
      , ("harm7",   [0,10,18,25])    -- ハーモニックセブンス 4:5:6:7(31EDOの看板。ほぼ唸らない)
      , ("min",     [0,8,18])        -- 短三和音 ≈ 10:12:15
      , ("submin",  [0,7,18])        -- サブマイナー ≈ 6:7:9(7/6の暗く滑らかな響き)
      , ("harmdim", [0,8,15])        -- 倍音減三和音 ≈ 5:6:7(12EDOの減三和音と違い協和的)
      , ("submin7", [0,7,18,25])     -- サブマイナー7
      -- ── 中程度の協和 ──
      , ("supmaj",  [0,11,18])       -- スーパーメジャー、3度 ≈ 9:7。硬く明るい緊張感
      , ("neut",    [0,9,18])        -- 中立3度 ≈ 11:9。長短どちらでもない浮遊感
      , ("aug",     [0,10,20])       -- 増三和音、20歩 ≈ 25:16。12EDOよりまろやか
      , ("maj7",    [0,10,18,28])    -- 長7、15/8 がやや純正に近く 12EDO より穏やか
      , ("harm9",   [0,10,18,25,36]) -- 4:5:6:7:9 の9th。高次倍音まで積んでも澄んでいる
      -- ── ふつうの機能和声用(ミーントーン)──
      , ("dim",     [0,8,16])        -- 減三和音
      , ("sus2",    [0,5,18])
      , ("sus4",    [0,13,18])
      , ("min7",    [0,8,18,26])
      , ("dom7",    [0,10,18,26])
      -- ── 不協和 ──
      , ("neut2",   [0,4,18])        -- 中立2度(4歩 ≈ 155¢ ≈ 11:10)を含む。強いうなり
      , ("wolf5f",  [0,10,17])       -- 狭5度。5度が1歩ずれると急激に濁る(ウルフ的)
      , ("wolf5s",  [0,10,19])       -- 広5度(同上)
      , ("clu3",    [0,3,6])         -- 全音階的半音(3歩)のクラスター
      , ("clu2",    [0,2,4])         -- クロマチック半音(2歩 ≈ 77¢)の密集
      -- ── 極端に不協和(31EDO特有)──
      , ("clu1",    [0,1,2])         -- ディエシス・クラスター(約39¢間隔)。
                                     -- ほぼ同音のうなりの塊で、12EDOには存在しない粗さ
      ]
    -- 3. chordTable31 … ルート×変化記号×種類 の全組み合わせから
    --    「名前 → 和音(ステップ数の stack)」の対応表を作る。
    --    ch31 は inhabit でパターン中の名前を表から引き、e31 で音程に変換する。
    chordTable31 =
      [ (r ++ a ++ sep ++ q, stack (map (pure . (+ (rv + av))) steps))
      | (r,rv) <- roots31, (a,av) <- accs31, sep <- [":", "'"], (q,steps) <- quals31 ]
    ch31 p = e31 (note (inhabit chordTable31 p))
    -- ── アルペジオ(和音を分散して鳴らす)────────────────────
    -- 和音イベントを n 等分の一定グリッドにし、構成音を下から順に循環させる。
    -- (標準の arp は構成音の数だけ音を置くため、3和音と4和音が混ざると
    --  リズムが不均等になる。arpSteady は和音の音数によらず一定になる)
    -- 例: arpSteady 8 (ch31 "<c:maj f:harm7>") — 各和音を8音の分散和音に
    arpSteady :: Int -> Pattern a -> Pattern a
    arpSteady n = arpWith (\es -> map (\i -> es !! (i `mod` length es)) [0 .. n-1])
    -- ── 単音(音名で呼び出す)────────────────────────────────
    -- roots31 × accs31 × オクターブ番号 の対応表。和音と同じ inhabit 方式。
    --   "c" "ds" "ehf" のような素の名前はオクターブ5(note 0 の高さ)、
    --   "c4" "ahf6" のように数字を付けるとオクターブ指定(c5 = 0 が基準)。
    -- 例: n31 "<c ds g>" |+ note "c2"(レジスタは note の加算でも動かせる)
    noteTable31 =
      [ (r ++ a ++ oname, pure (rv + av + fromIntegral (31 * (o - 5))))
      | (r,rv) <- roots31, (a,av) <- accs31
      , (oname,o) <- ("",5) : [(show n, n) | n <- [0..8 :: Int]] ]
    n31 p = e31 (note (inhabit noteTable31 p))
    -- ── スケール(音律)──────────────────────────────────────
    -- スケールは「オクターブ(31ステップ)内のステップ数のリスト」で定義。
    --   orwell9   : Orwell[9]。生成音程 7\31(サブマイナー3度 ≈7:6)による
    --               9音MOS。12EDOに存在しない、31EDOの代表的スケール
    --   mohajira  : 中立3度(9\31 ≈11:9)を積んだ7音スケール。アラブ音楽の
    --               ラースト系に近い、長短の中間の響き
    --   miracle10 : Miracle[10](デシマル)。セコール(3\31 ≈116.1セント)を
    --               生成音程とする10音のほぼ等間隔スケール
    --   harmonics : 倍音列の第8〜16倍音。第11・13倍音(14, 22)を含む
    --   major     : ミーントーン全音階の長調(31EDOは1/4コンマ・ミーントーン
    --               とほぼ同じなので、純正に近い長3度をもつ)
    --   minor     : ミーントーン自然的短音階
    --   chrom12   : ミーントーンの12音クロマチック(全音=5を 2+3 に分割)
    scales31 :: [(String, [Note])]
    scales31 =
      [ ("orwell9",   [0,4,7,11,14,18,21,25,28])
      , ("mohajira",  [0,5,9,14,18,23,27])
      , ("miracle10", [0,3,6,9,12,15,18,21,24,27])
      , ("harmonics", [0,5,10,14,18,22,25,28])
      , ("major",     [0,5,10,13,18,23,28])
      , ("minor",     [0,5,8,13,18,21,26])
      , ("chrom12",   [0,2,5,7,10,13,15,18,20,23,25,28])
      ]
    -- scale31 は Tidal 標準の scale と同じ使い方。度数がスケールの音数を
    -- 超えると 31ステップ(=1オクターブ)上に折り返す(負の度数は下へ)。
    step31 sc x = sc !! (x `mod` length sc) + fromIntegral (31 * (x `div` length sc))
    scale31 :: Pattern String -> Pattern Int -> Pattern Note
    scale31 sp p = innerJoin (fmap (\name -> fmap (step31 (maybe [0] id (lookup name scales31))) p) sp)
    -- scale31on はルート音名を指定して、スケールをそのルート上に移調する。
    -- 例: scale31on "d" "orwell9" "0 1 2" — D をルートにした orwell9 の 0〜2度
    -- (度数 0 = ルート音。和音のルートに合わせたチャーチモード的な使い方)
    scale31on :: Pattern String -> Pattern String -> Pattern Int -> Pattern Note
    scale31on rp sp p = scale31 sp p |+ inhabit noteTable31 rp

-- ============================================================
-- 使用例: 協和 → 不協和のグラデーション(C4 をルートに quals31 全22種)
-- ============================================================
-- 同じルート C の上で、quals31 の定義順のまま響きを崩していく
-- (各和音1サイクル、22サイクルで一周)。
--
--   非常に協和(倍音列の整数比にほぼ一致):
--     c:maj → c:harm7 → c:min → c:submin → c:harmdim → c:submin7
--   中程度の協和(中立・スーパー系の中間色):
--     c:supmaj → c:neut → c:aug → c:maj7 → c:harm9
--   ふつうの機能和声用(ミーントーン):
--     c:dim → c:sus2 → c:sus4 → c:min7 → c:dom7
--   不協和(うなり・ウルフ・クラスター):
--     c:neut2 → c:wolf5f → c:wolf5s → c:clu3 → c:clu2
--   極端に不協和(31EDO特有):
--     c:clu1 — ディエシス・クラスター。約39¢間隔のほぼ同音のうなりの塊
--
-- ch31 のルート c は素の状態で c5(note 0)なので、|+ note "c4" で
-- 1オクターブ下げて C4 をルートにしている。
-- 低域ほどうなりが粗く聞こえるので、不協和側の変化がよくわかる。

resetCycles

d1
  $ s "superrhodes"
  # ch31 "<c:maj c:harm7 c:min c:submin c:harmdim c:submin7 c:supmaj c:neut c:aug c:maj7 c:harm9 c:dim c:sus2 c:sus4 c:min7 c:dom7 c:neut2 c:wolf5f c:wolf5s c:clu3 c:clu2 c:clu1>"
  |+ note "c4"
  # legato 1
  # gain 0.9

hush

-- ============================================================
-- 使用例: コード進行 — 協和側16種(maj〜dom7)を1回ずつ使う
-- ============================================================
-- quals31 の maj から dom7 まで(不協和グループを除く16種)をちょうど
-- 1回ずつ使った、C を中心とする機能的な進行(各和音1サイクル、
-- 16サイクルで一周)。ミーントーンの機能和声(I–ii–IV–V–vii°)を骨格に、
-- 同じ機能の和音を 31EDO 特有の色(7:6, 9:7, 11:9, 5:6:7, 4:5:6:7:9)で
-- 塗り替えながら進む:
--
--   c:maj      I            … 主和音から出発
--   c:aug      I+           … 5度が半音ずつ上がる経過和音(18→20→23)
--   a:min      vi           … 増5度(20)の解決先。平行短調へ
--   d:submin   ii(7:6)      … ii の3度がセプティマルに沈む
--   g:sus4     Vsus4        … ドミナント準備
--   g:dom7     V7           … 4度が3度へ解決(31→28)する定番の流れ
--   c:harm7    I7(4:5:6:7)  … 自然7度のトニック = IV へのセカンダリードミナント
--   f:maj7     IVmaj7       … サブドミナントへ解決
--   f:supmaj   IV(9:7)      … 同じ IV を硬く明るい 9:7 で照らし直す(25→24)
--   d:min7     ii7          … 下属機能の連鎖
--   b:dim      vii°         … 導音上の減三和音(ドミナント機能)
--   c:sus2     Isus2        … いったん主和音圏へ柔らかく着地
--   d:neut     ii(11:9)     … 中立3度の ii で長短があいまいに
--   g:submin7  v7(7:6)      … 微分音の影を帯びたドミナント
--   b:harmdim  vii(5:6:7)   … 協和的な倍音減三和音。B・D を保ったまま
--                             最低限の動きで次の属9へつながる
--   g:harm9    V9(4:5:6:7:9)… 倍音列そのままの属9和音で c:maj へ戻る

do
  -- resetCycles
  -- ベース: 進行のルートを音名で演奏(n31 で単音)
  setcps(80/240)
  d1
    $ s "supermoog(5, 8)"
    # n31 "<c c a d g g c f f d b c d g b g>"
    |+ note "[c2 c3]*2"
    # legato 1
    # lpf (range 200 1200 $ rand) # resonance 0.3
    # gain 0.9
  -- 和音: 16種を1回ずつ使った進行(各和音1サイクル)
  d2
    $ s "superrhodes"
    # ch31 "<c:maj c:aug a:min d:submin g:sus4 g:dom7 c:harm7 f:maj7 f:supmaj d:min7 b:dim c:sus2 d:neut g:submin7 b:harmdim g:harm9>"
    |+ note "c4"
    # legato 1
    # gain 0.85
  -- アルペジオ: d2 と同じコードネームから直接生成。arpSteady 8 が
  -- 各和音を8等分の一定グリッドにするので、3〜5和音が混ざっても
  -- リズムは一定のまま(g:harm9 の5音もそのまま循環する)。
  -- mask "t(5,8)" で8グリッドのうちユークリッドリズム (5,8) の位置
  -- (x.xx.xx.)だけを鳴らす。鳴る音はグリッド上の構成音そのままなので、
  -- 和音との整合は保たれる
  d3
    $ mask "t(7,8)"
    $ arpSteady 8
    $ ch31 "<c:maj c:aug a:min d:submin g:sus4 g:dom7 c:harm7 f:maj7 f:supmaj d:min7 b:dim c:sus2 d:neut g:submin7 b:harmdim g:harm9>"
    # s "superhammond"
    # voice 8
    |+ note "<c5 c6>*4"
    # legato 0.9
    # delay 0.7 # delaytime ("[5, 7]"/16) # delayfb 0.75 # lock 1
    # gain 0.7

hush

-- ============================================================
-- 差し替え用: 同じ進行の静謐版 — superhammond のドローン主体
-- ============================================================
-- コード進行は上とまったく同じ16和音のまま、slow 4 で各和音を
-- 4サイクルに引き延ばし、全パートを superhammond の持続音に置き換える。
-- 和音の切り替わりは重なりで溶かす: legato 1.25 により各和音は自分の
-- 長さの 1/4(=1サイクル)だけ次の和音に食い込んで鳴り続けるので、
-- 移行部では新旧2つの和音が同時に響き、前の和音の余韻の中から次の
-- 和音が浮かび上がってくる。
--   d1 … ルートのドローン(C2+C3 の2オクターブ重ね。lpf 500 で暗く沈める。
--         ベースまで重ねると濁るので、重なりは短め)
--   d2 … 和音のドローン(主体。1サイクル分のクロスフェード的な重なり)
--   d3 … 高域の残光(構成音を4サイクルに3音だけ置き、強めのディレイの
--         フィードバックで前の和音の粒を次の和音の上まで漂わせる)

do
  -- resetCycles
  -- ルートのドローン
  d1
    $ slow 4
    $ s "superhammond"
    # voice 6
    # n31 "<c c a d g g c f f d b c d g b g>"
    |+ note "[c2, c3]"
    # legato 1.05
    # lpf 500
    # gain 0.8
  -- 和音のドローン(この版の主体)
  d2
    $ slow 4
    $ s "superhammond"
    # voice 8
    # ch31 "<c:maj c:aug a:min d:submin g:sus4 g:dom7 c:harm7 f:maj7 f:supmaj d:min7 b:dim c:sus2 d:neut g:submin7 b:harmdim g:harm9>"
    |+ note "c4"
    # legato 1.25
    # lpf 1500
    # room 0.7 # size 0.95
    # gain 0.7
  -- 高域の残光: arpSteady 8 のグリッドを mask "t(3,8)" で間引き、
  -- slow 4 で4サイクルに3音のゆっくりした点描にする。delayfb を上げて
  -- ディレイの尾が次の和音の領域まで残るように
  d3
    $ slow 4
    $ mask "t(3,8)"
    $ arpSteady 8
    $ ch31 "<c:maj c:aug a:min d:submin g:sus4 g:dom7 c:harm7 f:maj7 f:supmaj d:min7 b:dim c:sus2 d:neut g:submin7 b:harmdim g:harm9>"
    # s "superhammond"
    |+ note "c6"
    # legato 2
    # lpf 2500
    # delay 0.6 # delaytime (2/3) # delayfb 0.8 # lock 1
    # room 0.7 # size 0.95
    # gain 0.45

hush

-- ============================================================
-- 差し替え用: フェード版 — ルート C 固定で、響きだけが折り重なって変化する
-- ============================================================
-- ルートを常に C に固定し、quals31 の協和側16種の「響き」だけが
-- 移ろっていく版(各和音4サイクル)。エンベロープを持つシンセ
-- (supersaw / supersquare / superpwm は attack・hold・release を秒単位で
-- 指定できる。superhammond はオルガンなので不可)で鳴らし、さらに
-- 和音パッドを2つの層に分けて「全パートが同時に切り替わる瞬間」を
-- なくしてある。
--
-- 16種の順序は、隣り合う和音の差が最小(1〜3ステップの音の移動か、
-- 1音の追加・削除だけ)になるように並べてある。ルートと5度(0, 18)は
-- ほぼ常に鳴り続け、3度と7度だけが少しずつ滑っていく:
--   maj → maj7(28を足す)→ harm7(28→25)→ harm9(36を足す)
--   → dom7(36を消し 25→26)→ sus4(3度 10→13)→ sus2(13→5)
--   → neut(5→9)→ min(9→8)→ min7(26を足す)→ submin7(8→7, 26→25)
--   → submin(25を消す)→ harmdim(7→8, 5度 18→15)→ dim(15→16)
--   → aug(8→10, 16→20)→ supmaj(20→18, 10→11)→ maj へ戻る(11→10)
-- 長3度圏 → 倍音列圏 → sus圏 → 中立・短3度圏 → セプティマル圏 →
-- 減・増の緊張 → 長3度圏へ帰還、という一筆書きの円環になっている。
--
-- 継ぎ目を消す2つの仕掛け:
--  (1) 深いクロスフェード … エンベロープは発音した瞬間から
--      attack+hold+release 秒かけて最後まで進む(イベントの枠で切られ
--      ない)。合計をイベント長(12秒)より大きくした分だけ、前の和音の
--      消え際と次の和音の立ち上がりが重なる。
--  (2) 層をずらす … 同じ進行のパッドを2層(d2・d4)用意し、d4 を
--      2サイクル(=半和音分)遅らせる。和音の変わり目は
--        d2: 0秒・12秒・24秒…  /  d4: 6秒・18秒・30秒…
--      と交互に訪れるため、どの瞬間もどちらか一方の層は和音の真ん中を
--      持続しており、その持続の陰でもう一方がゆっくり入れ替わる。
--      境界が時間軸上で分散し、「切り替わった」と聞こえる点が消える。
--
-- 時間設計(setcps(80/240) → 1サイクル3秒、1和音 = 4サイクル = 12秒):
--   d1 ベース    : attack 3 + hold 5 + release 4 = 12秒(重ねない。低域の濁り防止)
--   d2 パッド層A : attack 5 + hold 4 + release 7 = 16秒 → 4秒重なる
--   d4 パッド層B : 同じ設定を2サイクル遅らせたもの(gain は少し控えめ)
--   d3 点描      : attack 1 + hold 1 + release 4 = 6秒。粒がディレイで漂う
-- ※ cps を変える場合はこれらの秒数も合わせて調整すること

do
  -- resetCycles
  -- ベース: supersquare を暗くフィルタした C のドローン(ルートは動かない)
  d1
    $ slow 8
    $ s "supersquare"
    # n31 "c"
    |+ note "[c4, c3]"
    # attack 16 # decay 16
    # lpf 2000
    # gain 0.7
  -- 和音パッド層A: supersaw。5秒かけて浮かび、7秒かけて沈む
  d2
    $ slow 4
    $ s "supersaw"
    # ch31 "<c:maj c:maj7 c:harm7 c:harm9 c:dom7 c:sus4 c:sus2 c:neut c:min c:min7 c:submin7 c:submin c:harmdim c:dim c:aug c:supmaj>"
    |+ note "c4"
    # attack 16 # decay 16
    # lpf 2000
    # room 0.7 # size 0.95
    # gain 0.5
  -- 和音パッド層B: 層Aと同じ進行を2サイクル(半和音分)遅らせる。
  -- 1オクターブ上・暗めのフィルタで、層Aの陰から遅れて浮かび上がる
  d4
    $ (2 ~>)
    $ slow 4
    $ s "supersaw"
    # ch31 "<c:maj c:maj7 c:harm7 c:harm9 c:dom7 c:sus4 c:sus2 c:neut c:min c:min7 c:submin7 c:submin c:harmdim c:dim c:aug c:supmaj>"
    |+ note "c5"
    # attack 16 # decay 16
    # lpf 2000
    # room 0.7 # size 0.95
    # gain 0.4
  -- 高域の残光: superpwm の点描(4サイクルに3音)。短い attack と
  -- 長い release で1粒ずつ膨らんで消える
  d3
    $ slow 4
    $ mask "t(3,8)"
    $ arpSteady 8
    $ ch31 "<c:maj c:maj7 c:harm7 c:harm9 c:dom7 c:sus4 c:sus2 c:neut c:min c:min7 c:submin7 c:submin c:harmdim c:dim c:aug c:supmaj>"
    # s "superpwm"
    |+ note "c6"
    # attack 1 # hold 2 # release 4
    # lpf 2500
    # delay 0.6 # delaytime (2/3) # delayfb 0.8 # lock 1
    # room 0.7 # size 0.95
    # gain 0.4

hush

-- ============================================================
-- 作品スケッチ: ミーントーンの聖歌 — Kali Malone 風の持続オルガン
-- ============================================================
-- Kali Malone が弾く歴史的オルガンの多くは 1/4 コンマ・ミーントーン
-- 調律で、31EDO はその実用上の等分化(長3度がほぼ純正 5:4)。
-- つまり superhammond + 31EDO は彼女の音世界を再現するのに最も
-- 理にかなった組み合わせになる。
--
-- 設計:
--  ・4声のオルガン・コラール(ペダル/テナー/アルト/ソプラノ)。
--    オルガンは音が減衰しないので、フェードではなく「声部の保続」で
--    連続性を作る — どの瞬間も大半の声部は音を保持しており、
--    1声だけが静かに次の音へ移る。
--  ・各声部の音価を互いに素な周期(slow 8 / 7 / 5 / 9)にしてあるため、
--    声部の変わり目はほとんど重ならず、和音は「切り替わる」のではなく
--    1音ずつ組み変わっていく。全体が一巡するのは数万サイクル先で、
--    実質的に反復しない長時間形式になる。
--  ・声部が行き違う瞬間に掛留(サスペンション)や短2度・ウルフ的な
--    うなりが偶発し、純正な長3度に解決していく — このうなり→解決の
--    呼吸が Malone 的な時間感覚の核。
--  ・アルト声部は 3度の質を e(5:4)→ ehf(11:9)→ ef(6:5)と
--    1ディエシスずつ滑らせる。12EDO では不可能な「和音の内側だけが
--    ゆっくり明暗を変える」動き。
--  ・vibrato 0(トレムラントなし)、legato 1.02 で音の切れ目を塞ぐ。
--
-- テンポ: setcps(60/240) → 1サイクル4秒。
--   ペダル32秒 / テナー28秒 / アルト20秒 / ソプラノ36秒 ごとに1音。

do
  resetCycles
  setcps (60/240)
  -- ペダル: C を保続し、まれに G(属)と A(平行短調の影)へ沈む
  d1
    $ slow 8
    $ s "superhammond"
    # voice 0
    # n31 "<c c c g c a c g>"
    |+ note "c2"
    # vibrato 0
    # legato 1.02
    # lpf 600
    # room 0.8 # size 0.95
    # gain 0.8
  -- テナー: 5度・4度・6度を行き来する中声部
  d2
    $ slow 7
    $ s "superhammond"
    # voice 3
    # n31 "<g f g e c f e g>"
    |+ note "c3"
    # vibrato 0
    # legato 1.02
    # lpf 1200
    # room 0.8 # size 0.95
    # gain 0.7
  -- アルト: 3度の質のドリフト(純正長3度 → 中立 → 短3度)。
  -- この声部だけ周期が短く、和音の「内側の明暗」を主導する
  d3
    $ slow 5
    $ s "superhammond"
    # voice 5
    # n31 "<e e ehf ef e f e ef ehf e>"
    |+ note "c4"
    # vibrato 0
    # legato 1.02
    # lpf 1800
    # room 0.8 # size 0.95
    # gain 0.65
  -- ソプラノ: 休符をはさんで浮かぶ上声。as(25歩)は C の自然7度
  -- (4:5:6:7 の頂点)で、現れるたびに和音が倍音列に静かに整列する
  d4
    $ slow 9
    $ s "superhammond"
    # voice 8
    # n31 "<c ~ b as ~ a as g>"
    |+ note "c5"
    # vibrato 0
    # legato 1.02
    # lpf 2200
    # room 0.8 # size 0.95
    # gain 0.5

hush
