let edo = 31 -- 31EDOの1オクターブのステップ数
    e31 p = p |* note (12/edo)
    -- 31EDOのルート音(ステップ数): 全音 = 5、全音階的半音 = 3
    roots31 = [("c",0),("d",5),("e",10),("f",13),("g",18),("a",23),("b",28)]
    -- 変化記号: s/f = 半音階的半音(2ステップ)、hs/hf = 半シャープ/半フラット(1ステップ)
    accs31 = [("",0),("s",2),("f",-2),("hs",1),("hf",-1)]
    -- 和音の種類(31EDOステップで定義)
    quals31 =
      [ ("maj",     [0,10,18])     -- 長三和音、3度 ≈ 5:4
      , ("min",     [0,8,18])      -- 短三和音、3度 ≈ 6:5
      , ("neut",    [0,9,18])      -- 中立3度 ≈ 11:9
      , ("submin",  [0,7,18])      -- サブマイナー、3度 ≈ 7:6
      , ("supmaj",  [0,11,18])     -- スーパーメジャー、3度 ≈ 9:7
      , ("dim",     [0,8,16])
      , ("aug",     [0,10,20])
      , ("sus2",    [0,5,18])
      , ("sus4",    [0,13,18])
      , ("maj7",    [0,10,18,28])
      , ("min7",    [0,8,18,26])
      , ("dom7",    [0,10,18,26])
      , ("harm7",   [0,10,18,25])  -- 自然7度和音 4:5:6:7
      , ("submin7", [0,7,18,25])
      ]
    chordTable31 =
      [ (r ++ a ++ sep ++ q, stack (map (pure . (+ (rv + av))) steps))
      | (r,rv) <- roots31, (a,av) <- accs31, sep <- [":", "'"], (q,steps) <- quals31 ]
    ch31 p = e31 (note (inhabit chordTable31 p))
    -- 31EDO特有のスケール(31ステップのオクターブ内のステップ数で定義)
    scales31 :: [(String, [Note])]
    scales31 =
      [ ("orwell9",   [0,4,7,11,14,18,21,25,28])  -- Orwell[9]、生成音程 7\31(サブマイナー3度)
      , ("mohajira",  [0,5,9,14,18,23,27])        -- 中立3度(≈11:9)による7音スケール
      , ("harmonics", [0,5,10,14,18,22,25,28])    -- 倍音列 第8〜16倍音(第11・13倍音を含む)
      , ("major",     [0,5,10,13,18,23,28])       -- ミーントーン全音階の長調
      , ("minor",     [0,5,8,13,18,21,26])        -- ミーントーン自然的短音階
      ]
    -- Tidalのscale関数と同じ使い方、ただしオクターブは31ステップで折り返す
    step31 sc x = sc !! (x `mod` length sc) + fromIntegral (31 * (x `div` length sc))
    scale31 :: Pattern String -> Pattern Int -> Pattern Note
    scale31 sp p = innerJoin (fmap (\name -> fmap (step31 (maybe [0] id (lookup name scales31))) p) sp)
    -- 32サイクルの形式: キーの中心が下方倍音列(ユートナリティ)を降りていく
    -- C (0) -> 中立3度下 (-9) -> 5度下 (-18) -> 自然7度下 (-25)、各8サイクル
    -- test01の上行形式の鏡像
    key31 :: Pattern Note
    key31 = slow 8 "<0 -9 -18 -25>"
    inKey p = p |+ e31 (note key31)
    -- 形式の最終サイクル: 全体が1ディエシス(38.7セント)下にスライドする
    pump = whenmod 32 31 (|- e31 (note 1))

hush

setcps(120/240)

resetCycles

d1
  $ pump . inKey
  $ s "superhammond"
  # voice 8
  -- ルートがサブマイナー3度(7\31 = Orwellの生成音程)ずつ下降し続ける8和音
  -- c(0) -> ahs(24) -> ghf(17) -> e(10) -> df(3) -> bhf(27) -> gs(20) -> f(13)
  # ch31 "<c:submin7 ahs:neut ghf:harm7 e:min7 df:supmaj bhf:submin7 [gs:sus2 gs:harm7] [f:supmaj g:harm7]>"
  |+ note "[c4, c5, c6]"
  |* note "[0.999, 1.001]"
  # legato "1.0"
  -- # leslie 0.99 # speed 0.5
  # room 0.9 # size 0.3
  # gain 1.1

d2
  $ pump . inKey
  $ jux (iter 14)
  -- d1と同じ進行をユークリッドリズムに乗せて断続的に刻むコードスタブ
  $ struct "t(<5 9 5 11>, 14, <0 0 2 4>)"
  $ s "superhammond"
  # voice 1
  # ch31 "<c:submin7 ahs:neut ghf:harm7 e:min7 df:supmaj bhf:submin7 [gs:sus2 gs:harm7] [f:supmaj g:harm7]>"
  |+ note "[c5, c6]"
  |* note "[0.999, 1.001]"
  # delay 0.9 # delaytime (5/14) # delayfb "0.2" # lock 1
  -- # lpf (range 8000 12000 $ slow 4 $ sine) # resonance "0.2"
  # legato 0.5
  # gain 1.2

d3
  $ pump . inKey
  $ struct "t(<3 5 3 5>, 7)"
  $ s "superbass"
  # e31 (note "<0 24 17 10 3 27 [20 7] [13 0]>")
  |+ note "c3"
  # legato 0.9
  # lpf (range 800 4000 $ rand) # resonance "0.3"
  # gain 1.3

d4
  -- $ jux (("[3, 9]"/14)<~)
  $ stack
  [
    s "uni(3, 14)" # gain 1.5
    , s "uni:1(9, 14, 2)"
  ]
  -- # delay 0.8 # delaytime (9/14) # delayfb "0.5" # lock 1  
  |* gain 1.7

d5
  -- $ jux (("[13, 5]"/14)<~)
  -- 14グリッド上に3層のリズムを重ね、ply でロールを差し込む
  $ sometimesBy 0.15 (ply "<2 3>")
  $ stack
  [ -- 主軸: パルス数がサイクルごとに変わるユークリッド
    s "ifdrums(<7 10 9 11>, 14)"
    # n (range 1 4 $ rand)
    # gain 1.0
  , -- 裏打ち: オフセットがずれていくカウンターリズム
    s "ifdrums(<3 5>, 14, <0 3 6>)"
    # n (range 4 8 $ rand)
    # speed 2 # gain 0.85
  , -- 細分化: 28分割(14×2)を虫食いにしたチャター
    degradeBy 0.55
    $ s "ifdrums*28"
    # n (irand 8)
    # speed 4 # gain 0.75
  ]
  # shape 0.7
  |* gain 1.1



hush