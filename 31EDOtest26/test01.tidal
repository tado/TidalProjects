let edo = 31 -- 31EDOの1オクターブのステップ数
    e31 p = p |* note (12/edo)
    -- 31EDOのルート音(ステップ数): 全音 = 5、全音階的半音 = 3
    roots31 = [("c",0),("d",5),("e",10),("f",13),("g",18),("a",23),("b",28)]
    -- 変化記号: s/f = 半音階的半音(2ステップ)、hs/hf = 半シャープ/半フラット(1ステップ)
    accs31 = [("",0),("s",2),("f",-2),("hs",1),("hf",-1)]
    -- 和音の種類(31EDOステップで定義)
    quals31 =
      [ ("maj",     [0,10,18])     -- 長三和音、3度 ≈ 5:4
      , ("min",     [0,8,18])      -- 短三和音、3度 ≈ 6:5
      , ("neut",    [0,9,18])      -- 中立3度 ≈ 11:9
      , ("submin",  [0,7,18])      -- サブマイナー、3度 ≈ 7:6
      , ("supmaj",  [0,11,18])     -- スーパーメジャー、3度 ≈ 9:7
      , ("dim",     [0,8,16])
      , ("aug",     [0,10,20])
      , ("sus2",    [0,5,18])
      , ("sus4",    [0,13,18])
      , ("maj7",    [0,10,18,28])
      , ("min7",    [0,8,18,26])
      , ("dom7",    [0,10,18,26])
      , ("harm7",   [0,10,18,25])  -- 自然7度和音 4:5:6:7
      , ("submin7", [0,7,18,25])
      ]
    chordTable31 =
      [ (r ++ a ++ sep ++ q, stack (map (pure . (+ (rv + av))) steps))
      | (r,rv) <- roots31, (a,av) <- accs31, sep <- [":", "'"], (q,steps) <- quals31 ]
    ch31 p = e31 (note (inhabit chordTable31 p))
    -- 31EDO特有のスケール(31ステップのオクターブ内のステップ数で定義)
    scales31 :: [(String, [Note])]
    scales31 =
      [ ("orwell9",   [0,4,7,11,14,18,21,25,28])  -- Orwell[9]、生成音程 7\31(サブマイナー3度)
      , ("mohajira",  [0,5,9,14,18,23,27])        -- 中立3度(≈11:9)による7音スケール
      , ("harmonics", [0,5,10,14,18,22,25,28])    -- 倍音列 第8〜16倍音(第11・13倍音を含む)
      , ("major",     [0,5,10,13,18,23,28])       -- ミーントーン全音階の長調
      , ("minor",     [0,5,8,13,18,21,26])        -- ミーントーン自然的短音階
      ]
    -- Tidalのscale関数と同じ使い方、ただしオクターブは31ステップで折り返す
    step31 sc x = sc !! (x `mod` length sc) + fromIntegral (31 * (x `div` length sc))
    scale31 :: Pattern String -> Pattern Int -> Pattern Note
    scale31 sp p = innerJoin (fmap (\name -> fmap (step31 (maybe [0] id (lookup name scales31))) p) sp)
    -- 32サイクルの形式: キーの中心が自然7度和音そのものを昇っていく
    -- C (0) -> 中立3度 (9) -> 5度 (18) -> 自然7度 (25)、各8サイクル
    key31 :: Pattern Note
    key31 = slow 8 "<0 9 18 25>"
    inKey p = p |+ e31 (note key31)
    -- 形式の最終サイクル: 全体が1ディエシス(38.7セント)上にスライドする
    pump = whenmod 32 31 (|+ e31 (note 1))

hush

setcps(130/240)

resetCycles

d1
  $ pump . inKey
  $ s "superhammond"
  # voice 7
  # ch31 "<c:harm7 ahf:neut f:submin7 dhf:supmaj d:submin7 [g:sus4 g:harm7] [c:maj ehf:aug] [f:supmaj g:supmaj]>"
  |+ note "c4"
  # legato "1.0"
  -- # leslie 0.8 # speed 0.2
  # room 0.9 # size 0.9
  # gain 1.1

d2
  $ pump . inKey
  $ jux (iter 14)
  $ s "superpwm(<9 11 9 14>, 14)"
  # e31 (note (scale31 (slow 8 "<orwell9 mohajira harmonics orwell9>") "<[0 4 2 7 4 9 11] [9 13 11 9 7 4 2] [0 4 2 7 ~ 9 11] [14 11 9 7 4 2 0]>*2"))
  |+ note "c3"
  # delay 0.8 # delaytime ("[5, 9]"/14) # delayfb "0.5" # lock 1
  # lpf (range 200 8000 $ rand) # resonance "0.2"
  -- # room 0.8 # size 0.8
  # legato 0.8
  # gain 1.0

d3
  $ pump . inKey
  $ struct "t(<3 5 3 5>, 7)"
  $ s "superbass"
  # e31 (note "<0 22 13 4 5 18 [0 9] [13 18]>")
  |+ note "c2"
  # legato 0.9
  # lpf (range 400 2000 $ rand) # resonance "0.3"
  # gain 1.1

d4
  $ jux (("[3, 9]"/14)<~)
  $ stack
  [
    s "uni(3, 14)" # gain 1.3
    , s "uni:1(9, 14, 2)"
  ]
  -- # delay 0.8 # delaytime (9/14) # delayfb "0.5" # lock 1  
  |* gain 1.3

unsolo 4

hush

d5
  $ jux (("[13, 5]"/14)<~)
  $ s "ifdrums(10, 14)"
  # n (range 1 4 $ rand)
  # shape 0.7
  # gain 1.0



hush