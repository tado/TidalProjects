unsolo 6  

d7 silence

  $ jux ((5/14)<~)  
  $ s "superwho(9, 14)"
  # note "g7'maj11"
  |+ note "[0, 12]"
  # legato 0.6
  # lfo (range 800 8000 $ rand) # resonance "0.3"
  -- # delay 0.8 # delaytime ("[7, 3]"/14) # delayfeedback 0.5 # lock 1
  # gain 0.8

d2 silence
  
d3 silence

d4 silence

d5 silence

  >> d6 silence


