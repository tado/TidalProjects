d1
  $ sometimesBy 0.2 (fast 2)
  $ s "bd cp [~ bd] hc*2"
  # delay 0.7 # delaytime (5/8) # lock 1

d2
  $ s "supersaw(9, 16)"
  # note "c3"
  |+ note (scale "minPent" "{0..9}%5")
  # lfo (range 200 2000 $ slow 4 $ sine) # resonance 0.3

d3
  $ jux (iter 8)
  $ s "superhammond*4"
  # note "c4'min c4'sus2 c4'sus2 c4'min9"
  # legato 0.9

















-- Intro : performance start -------------
-- 評価順: do ブロック → d1 → d2 → d3 → d4 と徐々に重ねる

hush  

do
  hush
  resetCycles
  setcps(120/240)
  d12
    $ s "none"
    # td_s 1
  once
    $ s "matsu"

d1
  $ s "sfh(3, 8)"
  # n (choose[0..32])
  # pan (rand)
  # lpf (range 200 3000 $ slow 8 $ sine) # resonance 0.2
  # room 0.7 # size 0.95
  # gain 0.8

d2
  $ s "ae(5, 8, [0, 3])"
  # n (choose[0..4])
  # pan (rand)
  |+ note "[-12, 0]"
  |+ note "[-0.05, 0.05]"
  # delay 0.9 # delaytime (range 0.001 0.05 $ rand) # delayfeedback 0.9
  # room 0.7 # size 0.9
  # gain 0.7

d3
  $ s "superdown/8"
  # note "c5"
  # voice 600
  # speed "[1.5, 1.0]"
  # legato 4.0
  # room 0.6 # size 0.95
  # gain 0.8

d4
  $ jux (("[3, 5]"/14)<~)
  $ s "uni(1, 7)"
  # legato 0.5
  # delay 0.6 # delaytime ("[5, 3]"/14) # delayfeedback 0.7 # lock 1
  # room 0.5 # size 0.9
  # gain 1.1

-- d4 発展形: 1打 → 7/14 ポリリズムへ
d4
  $ jux (("[3, 5]"/14)<~)
  $ sometimesBy 0.2 (fast 2)
  $ stack
  [
    s "uni(3, 14)" # legato 0.5
    , s "uni:1(2, 14, 5)" # shape 0.4 # gain 0.9
    , s "rs(3, 7, 2)" |+ note "[-12, 0]" # legato 0.4 # gain 0.8
  ]
  # delay 0.6 # delaytime ("[5, 3]"/14) # delayfeedback 0.7 # lock 1
  # room 0.5 # size 0.9
  # gain 1.1

-- d4 発展形2: hc が加わり密度が上がる
d4
  $ jux (("[3, 5, 9]"/14)<~)
  $ sometimesBy 0.3 (fast 2)
  $ sometimesBy 0.15 (rev)
  $ stack
  [
    s "uni(5, 14)" # legato 0.5
    , s "uni:1(3, 14, 5)" # shape 0.5 # gain 0.9
    , s "rs(3, 7, 2)" |+ note "[-12, <0 -5>/4]" # legato 0.4 # gain 0.8
    , s "hc(7, 14, 3)" # gain "<1.0 0.6>*14"
  ]
  # delay 0.5 # delaytime ("[5, 3]"/14) # delayfeedback 0.6 # lock 1
  # room 0.4 # size 0.9
  # gain 1.2

-- d5: リズムに重なる低音の和声パート
d5
  $ slow 2
  $ s "supermoog(3, 7)"
  # note "c2"
  |+ note (scale "minPent" "{0..4}%7")
  |+ note "[-0.04, 0.04]"
  # lpf (range 200 1500 $ slow 6 $ sine) # resonance 0.25
  # attack 1.5 # legato 4.0
  # room 0.6 # size 0.9
  # gain 1.0


-- Climax : 一気に Hard Beat へ(この do を一発評価)-------------

do
  setcps(140/240)
  d12
    $ s "none(11, 16)"
    # td_s (choose[1..100])
  d1
    $ every 2 (fast 2)
    $ jux (iter 16)
    $ stack
    [
      s "gabba(11, 16)" # gain 1.8
      , s "distd(13, 16, 7)" # gain 1.6
      , s "uni:1(9, 16, 3)" # n "{0 1 2 3}%5" # shape 0.9
      , s "ifdrums(7, 8, 1)" # n (irand 4) # gain 1.7
      , s "808(16, 16)" # n (irand 20) # shape 0.8 # gain 1.3
    ]
    # shape 0.8
    # delay 0.8 # delaytime (range 0.001 0.01 $ rand) # delayfeedback 0.9
    # room 0.1 # size 0.3
  d2
    $ every 3 (fast 2)
    $ s "superzow(16, 16)"
    # note "c2"
    |+ note (scale "minPent" "{0..24}%[5, 9, 13]")
    |+ note "<-12 0 12>*16"
    # lpf (range 200 12000 $ rand) # resonance 0.4
    # shape 0.6
    # gain 1.5
  d3
    $ jux (rev)
    $ s "superbass(13, 16)"
    # note "c1"
    |+ note (scale "minPent" "{0..9}%[5, 3]")
    |+ note "[-0.02, 0.02]"
    # legato 0.8
    # shape 0.3
    # gain 1.4
  d4
    $ every 3 (fast 2)
    $ sometimesBy 0.5 (brak)
    $ s "fb(16, 16)"
    # gain "<1.4 1.8 1.0>*16"
    # delay 0.9 # delaytime (range 0.001 0.05 $ rand) # delayfeedback 0.95
    # shape 0.8

-- さらに追い込む(第2波)
do
  setcps(160/240)
  d5
    $ every 4 (fast 7)
    $ jux (iter 5)
    $ s "supersin(16, 16)"
    # note (choose [36, 39, 43, 46, 48])
    |+ note "[-0.5, 0.5]"
    # legato (range 0.01 0.3 $ rand)
    # shape 0.6
    # room 0.2 # size 0.4
    # gain 1.4
  d6
    $ every 2 (fast 3)
    $ every 3 (rev)
    $ s "uni(13, 16)" # n (irand 4)
    # delay 1.0 # delaytime (range 0.003 0.05 $ rand) # delayfeedback 0.9
    # shape 0.7
    # gain 1.6


-- Outro : 静かなエンディング -------------
-- 1. 急減速 + matsu の鐘でビートを断ち切る

do
  setcps(85/240)
  d12
    $ s "none"
    # td_s 1
  once
    $ s "matsu"
    # note "[0, -12]"
    # gain 1.1
    # room 0.5 # size 0.8
  d1 silence
    >> d4 silence
    >> d5 silence
    >> d6 silence

-- 2. 残った d2/d3 をドローンに置き換える

do
  d2
    $ jux ((3/16)~>)
    $ s "superhammond(5, 16)"
    # voice 4
    # note "c4'sus4"
    |+ note (scale "ritusen" "{0..9}%[3, 5]")
    |+ note "[-0.05, 0.05]"
    |+ note "[0, -12]"
    # legato 2.0
    # room 0.7 # size 0.95
    # gain 0.8
  d3
    $ s "supersawfbk"
    # note "c2"
    # rq 0.9
    # legato 3.0
    # wet 0.5
    # room 0.3 # size 0.9
    # gain 1.2

-- 3. 長い響きの断片を浮かべる

d4
  $ s "matsu/8"
  # note "[0, -12]"
  # room 0.6 # size 0.95
  # gain 1.0

d5
  $ s "superdown/8"
  # note "c5"
  # voice 1000
  # legato 4.0
  # room 0.6 # size 0.95
  # gain 1.2

-- 4. 段階的に消していく(間を置きながら順に評価)

d3 silence

d2 silence

d5 silence

setcps(40/240)

-- 5. 最後は matsu/8 (d4) だけが残り、余韻の中で終了

do
  hush
  once
    $ s "none"
    # td_s 0


-- Groove part (前セクションの素材) -------------

d1
  $ swingBy (1/16) 4
  $ sometimesBy 0.15 (jux (rev))
  $ stack
  [
    s "bd(5, 16)" # gain 1.3
    , s "cp(2, 16, 4)"
    , s "hh(7, 16, 2)" # gain "<1.1 0.7>*8"
    , s "uni:1(3, 16, 10)" # shape 0.6 # gain 0.9
  ]
  # shape 0.4
  # delay 0.5 # delaytime (3/8) # delayfeedback 0.5 # lock 1
  # room 0.4 # size 0.6
  # gain 1.2

d2
  $ s "supersaw(8, 8)"
  # note "c3"
  |+ note (scale "minPent" "[0..8]")
  # lpf (range 400 2000 $ slow 4 $ sine)
  # resonance 0.3

d3
  $ swingBy (1/16) 4
  $ jux ((3/16)<~)
  $ s "superwho(5, 16, 2)"
  # note "<c4'min7 eb4'maj7 g4'sus4 bb3'maj7>/2"
  |+ note "[0, 12]"
  |+ note "[-0.05, 0.05]"
  # legato 1.5
  # lfo (range 800 6000 $ slow 8 $ sine) # resonance 0.2
  # room 0.5 # size 0.9
  # gain 0.85


















d1
 $ s "bd cp bd hh"






d1
  $ s "sfh(3, 8)"
  # n (choose[0..32])
  # pan (rand)
  # lpf (range 400 8000 $ slow 4 $ sine) # resonance 0.2
  # room 0.6 # size 0.9
  # gain 0.7

d2
  $ s "ae(5, 8, [0, 5])"
  # n (choose[0..4])
  # pan (rand)
  |+ note "[-12, 0]"
  |+ note "[-0.05, 0.05]"
  # delay 0.8 # delaytime (range 0.001 0.05 $ rand) # delayfeedback 0.9
  # room 0.7 # size 0.9
  # gain 0.8

d3
  $ jux (("[5, 9]"/14)<~)
