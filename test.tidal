once
  $ s "matsu"

do
  -- hush
  setcps(100/240)
  d1
    $ jux (("[3, 10, 5]"/14)<~)
    $ s "rs(1, 7)"  
    |+ note "[-0.05, 0.05]"
    |+ note "[-12, <0 -5>/4]"
    # legato 0.5
    # delay 0.5 # delaytime ("[5, 3]"/14) # delayfeedback 0.5 # lock 1
