hush


d1
 $ s "bd cp bd hh"






d1
  $ s "sfh(3, 8)"
  # n (choose[0..32])
  # pan (rand)
  # lpf (range 400 8000 $ slow 4 $ sine) # resonance 0.2
  # room 0.6 # size 0.9
  # gain 0.7

d2
  $ s "ae(5, 8, [0, 5])"
  # n (choose[0..4])
  # pan (rand)
  |+ note "[-12, 0]"
  |+ note "[-0.05, 0.05]"
  # delay 0.8 # delaytime (range 0.001 0.05 $ rand) # delayfeedback 0.9
  # room 0.7 # size 0.9
  # gain 0.8

d3
  $ jux (("[5, 9]"/14)<~)
  $ s "uni(5, 14)"
  # legato 0.5
  # shape 0.3
  # delay 0.4 # delaytime ("[3, 5]"/14) # delayfeedback 0.6 # lock 1
  # room 0.4 # size 0.8
  # gain 1.4



d1
  $ s "bd cp [~ bd] hh*2"
  # delay 0.7 # delaytime ("[3, 5]"/8) # lock 1

d2
  $ s "supersaw(11, 16)"
  # note "c2"
  # legato "<0.5 2.0>*4"
  |+ note (scale "minPent" "{0..15}%5")
  # lpf (range 200 2000 $ slow 2 $ sine) 
  # resonance 0.2











once
  $ s "matsu"

do
  -- hush
  setcps(100/240)
  d1
    $ jux (("[3, 10, 5]"/14)<~)
    $ s "rs(1, 7)"  
    |+ note "[-0.05, 0.05]"
    |+ note "[-12, <0 -5>/4]"
    # legato 0.5
    # delay 0.5 # delaytime ("[5, 3]"/14) # delayfeedback 0.5 # lock 1
    # lpf (choose [6000, 8000]) # resonance 0.7
    # room 0.5 # size 0.9

d2
  $ jux (("[7, 3]"/14)<~) 
  $ s "fb(3, 14, 5)"
  -- # n "<0..3>*9"
  # gain "<1.3 0.9>*16"
  # delay 0.1 # delaytime "<0.02 0.01 0.005>*8" # delayfeedback 0.7

d3
  $ jux (("[5, 9]"/14)<~)  
  $ s "uni(3, 14)"
  # legato 0.5
  -- # n "<0..3>*9"
  # gain 1.2
  -- # delay 0.1 # delaytime "<0.02 0.01 0.03>*8" # delayfeedback 0.7

d4
  $ stack
  [
    s "uni(3, 7)" # legato 0.4 # gain 1.2
    , s "fb(5, 14)"
  ]  
  # gain 1.3

d5
  $ jux ((5/14)<~)  
  $ stack
  [
    s "superwho(9, 14)" # note "g6'sus2"
    , s "superwho(9, 14, 5)" # note "g6'sus2" |+ note 7
    , s "superwho(9, 14, 10)" # note "g6'sus2" |+ note 12
  ]
  # lfo (range 800 8000 $ rand) # resonance "0.2"
  # legato "0.5 1.0"
  # gain 0.8
  
d3
  $ sometimesBy 0.4 (jux (rev))
  $ s "ifdrums(11, 14)"
  # n (irand 3)  
  # gain (range 1.0 1.7 $ rand)

d6
  $ sometimesBy 0.4 (jux (rev))
  $ s "hasu(3, 14)"
  # n (choose [0..13])
  |+ note "<[0, 12] [12, 24]>/4"
  # room 0.5 # size 0.9
  # gain 1.5

unsolo 6  

d7 silence

  $ jux ((5/14)<~)  
  $ s "superwho(9, 14)"
  # note "g7'maj11"
  |+ note "[0, 12]"
  # legato 0.6
  # lfo (range 800 8000 $ rand) # resonance "0.3"
  -- # delay 0.8 # delaytime ("[7, 3]"/14) # delayfeedback 0.5 # lock 1
  # gain 0.8

d2 silence
  
d3 silence

d4 silence

d5 silence

  >> d6 silence


do
  d12
    $ s "none*4"
    # td_s 1
  once
    $ s "matsu" 
    -- |+ note "[-0.1, 0.1]"
    # note "[0, -12]"
    # gain 1.0
    # room 0.5 # size 0.8

d1 silence


d1
  $ jux ((5/8)~>)
  $ s "bd cp [~ bd] <hc hc*4>"
  # room 0.5
  # delay 0.75 # delaytime (3/8) # lock 1

do
  let shift = "<0 0 -2 5 1 2>/4"
  d2
    $ s "supersaw(9, 16)"  
    # note "c3"
    |+ note (scale "minPent" "{0..12}%[9, 7]")
    |+ note shift
    # lpf (range 400 2000 $ slow 8 $ sine) # resonance 0.3
  d3    
    $ s "supermoog(11, 16, 3)"
    # note "c5'sus4 c5'min7 c5'sus2"
    |+ note "[0, 19]"
    |+ note shift
    # lpf (range 1200 2000 $ slow 6 $ sine) # resonance 0.2
    # gain 0.9

setcps(40/240)

hush








d1
  $ jux ((5/8)~>)
  $ s "bd cp [~ bd] <hc*4 hc>"
  # room 0.5
  # delay 0.7 # delaytime (3/8) # lock 1

do
  let shift = "<0 0 1 2 3>/4"
  d2
    $ s "supersaw(11, 16)"
    # note "c3"
    |+ note (scale "yu" "{0..12}%9")
    |+ note shift
    # lpf (range 200 8000 $ slow 4 $ sine) # resonance 0.3
    # delay 0.7 # delaytime (5/8) # lock 1
    # gain 0.9
  d3
    $ s "supermoog(7, 16)"
    # note "c5'sus4 c5'sus2"
    |+ note "[0, 12]"
    |+ note shift
    # lpf (range 200 8000 $ slow 6 $ sine) # resonance 0.2